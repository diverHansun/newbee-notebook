# Newbee Notebook Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Required)
# =============================================================================

# ZhipuAI API Key - Get from https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# Aliyun bailian DASHSCOPE API KEY - Get from https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# =============================================================================
# Embedding Configuration (Optional)
# =============================================================================

# Embedding provider:
# - qwen3-embedding (default)
# - zhipu
# EMBEDDING_PROVIDER=qwen3-embedding

# Qwen3 embedding mode:
# - local: load model from models/Qwen3-Embedding-0.6B
# - api: call DashScope embeddings API
# QWEN3_EMBEDDING_MODE=local

# Local mode options
# QWEN3_EMBEDDING_MODEL_PATH=models/Qwen3-Embedding-0.6B
# QWEN3_EMBEDDING_DEVICE=auto
# QWEN3_EMBEDDING_MAX_LENGTH=8192
# QWEN3_EMBEDDING_DIM=1024
# QWEN3_EMBEDDING_BATCH_SIZE=32

# API mode options
# QWEN3_EMBEDDING_API_MODEL=text-embedding-v4
# QWEN3_EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# =============================================================================
# Search Tools (Optional - for Chat mode)
# =============================================================================

# Tavily API Key - Get from https://tavily.com/
# Required for web search in Chat mode
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# PostgreSQL Configuration (Required for RAG modes)
# =============================================================================

# PostgreSQL connection settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=newbee_notebook
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password

# =============================================================================
# Elasticsearch Configuration (Optional - for hybrid retrieval)
# =============================================================================

# Elasticsearch URL
ELASTICSEARCH_URL=http://localhost:9200

# =============================================================================
# Index Configuration (Optional)
# =============================================================================

# pgvector table name (default: documents_qwen3_embedding)
# PGVECTOR_TABLE_NAME=documents_qwen3_embedding

# pgvector embedding dimension (default: 1024 for qwen3-embedding)
# PGVECTOR_EMBEDDING_DIM=1024

# Elasticsearch index name (default: newbee_notebook_docs)
# ES_INDEX_NAME=newbee_notebook_docs

# =============================================================================
# Application Settings (Optional)
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Enable verbose mode for debugging
# VERBOSE=false

# =============================================================================
# Redis Configuration (Required for Celery async tasks)
# =============================================================================

# Redis connection settings (must match docker-compose.yml)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# =============================================================================
# Celery Configuration (Required for async document processing)
# =============================================================================

# Celery broker and result backend URLs
# IMPORTANT: When running API on host machine, use localhost:6379
#            When running API in Docker, use redis:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Celery worker concurrency (optional, default: number of CPU cores)
# CELERY_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Document pipeline single-flight lock (recommended)
# -----------------------------------------------------------------------------
# Optional dedicated redis URL for pipeline lock. If not set, REDIS_URL /
# CELERY_BROKER_URL will be used automatically.
# PIPELINE_LOCK_REDIS_URL=redis://localhost:6379/0

# Lock TTL in seconds for one document pipeline execution.
# Increase this when processing very large documents.
# DOCUMENT_PIPELINE_LOCK_TTL_SECONDS=18000

# =============================================================================
# MinerU Configuration (Required for PDF processing)
# =============================================================================

# Enable/disable MinerU converters globally
# MINERU_ENABLED=true

# Processing mode:
# - cloud: MinerU official cloud service via v4 Smart Parsing API
# - local: local dockerized mineru-api service
MINERU_MODE=cloud

# ----------------------- Cloud mode settings -----------------------
# Required when MINERU_MODE=cloud
MINERU_API_KEY=

# Optional cloud settings
# MINERU_V4_API_BASE=https://mineru.net
# MINERU_V4_TIMEOUT=120
# MINERU_V4_POLL_INTERVAL=5
# MINERU_V4_MAX_WAIT_SECONDS=1800
# CDN 下载兜底：requests/OpenSSL 握手失败时，改用系统 curl
# MINERU_CDN_CURL_FALLBACK_ENABLED=true
# MINERU_CDN_CURL_BINARY=curl
# 紧急排障可用，默认不要开启
# MINERU_CDN_CURL_INSECURE=false
# MinerU circuit breaker (consecutive failures before cooldown)
# MINERU_FAIL_THRESHOLD=5
# MINERU_COOLDOWN_SECONDS=120

# ----------------------- Local mode settings -----------------------
# Default local API URL in Docker network
# MINERU_LOCAL_API_URL=http://mineru-api:8000

# Local backend:
# - pipeline (CPU)
# - hybrid-auto-engine (GPU)
# MINERU_BACKEND=pipeline

# OCR languages, comma-separated
# MINERU_LANG_LIST=ch,en

# Local processing timeout in seconds; 0 means no read timeout
# MINERU_LOCAL_TIMEOUT=0

# =============================================================================
# Flower (Optional monitoring, enabled via docker-compose profile \"monitor\")
# =============================================================================
# FLOWER_PORT=5555
