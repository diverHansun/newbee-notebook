# MediMind Agent Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Required)
# =============================================================================

# ZhipuAI API Key - Get from https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# =============================================================================
# Search Tools (Optional - for Chat mode)
# =============================================================================

# Tavily API Key - Get from https://tavily.com/
# Required for web search in Chat mode
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# PostgreSQL Configuration (Required for RAG modes)
# =============================================================================

# PostgreSQL connection settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medimind
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password

# =============================================================================
# Elasticsearch Configuration (Optional - for hybrid retrieval)
# =============================================================================

# Elasticsearch URL
ELASTICSEARCH_URL=http://localhost:9200

# =============================================================================
# Index Configuration (Optional)
# =============================================================================

# pgvector table name (default: documents)
# PGVECTOR_TABLE_NAME=documents

# pgvector embedding dimension (default: 1024 for ZhipuAI)
# PGVECTOR_EMBEDDING_DIM=1024

# Elasticsearch index name (default: medimind_docs)
# ES_INDEX_NAME=medimind_docs

# =============================================================================
# Application Settings (Optional)
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Enable verbose mode for debugging
# VERBOSE=false

# =============================================================================
# Redis (Optional for caching / Celery broker)
# =============================================================================
# Redis host/port/db; password left empty for local dev
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# =============================================================================
# Celery (Optional for async document processing)
# =============================================================================
# Override to point to a different broker/backend if needed
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CELERY_CONCURRENCY=4

# =============================================================================
# Flower (Optional monitoring, enabled via docker-compose profile \"monitor\")
# =============================================================================
# FLOWER_PORT=5555
