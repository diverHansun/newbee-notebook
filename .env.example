# Newbee Notebook Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Required)
# =============================================================================

# ZhipuAI API Key - Get from https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# Aliyun bailian DASHSCOPE API KEY - Get from https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# =============================================================================
# Model Runtime Switch (backend-v2 module2)
# =============================================================================

# Enable runtime model switch API/UI:
# - true: expose /api/v1/config/* and Control Panel Model tab
# - false: keep model switch disabled
FEATURE_MODEL_SWITCH=false

# =============================================================================
# Embedding Runtime Overrides (Optional)
# =============================================================================

# Embedding provider fallback used before DB runtime settings are applied.
# Supported values:
# - qwen3-embedding
# - zhipu
# EMBEDDING_PROVIDER=qwen3-embedding

# Qwen3 local embedding defaults.
# Use an absolute path if the model directory is outside the current working tree.
# QWEN3_EMBEDDING_MODE=local
# QWEN3_EMBEDDING_MODEL_PATH=models/Qwen3-Embedding-0.6B
# QWEN3_EMBEDDING_DEVICE=auto
# QWEN3_EMBEDDING_DIM=1024
# QWEN3_EMBEDDING_MAX_LENGTH=8192
# QWEN3_EMBEDDING_BATCH_SIZE=32

# Qwen3 API embedding defaults (used only when QWEN3_EMBEDDING_MODE=api).
# QWEN3_EMBEDDING_API_MODEL=text-embedding-v4
# QWEN3_EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# =============================================================================
# Built-in Search Tools (Optional, not injected by current batch-2 runtime)
# =============================================================================

# Tavily API Key - retained for built-in web search tools.
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# Storage Backend (backend-v2 MinIO phase 0/1)
# =============================================================================

# Storage backend:
# - local: use bind-mounted local filesystem
# - minio: use MinIO object storage backend
STORAGE_BACKEND=local

# Local storage root (effective when STORAGE_BACKEND=local)
DOCUMENTS_DIR=data/documents

# MinIO connection settings (effective when STORAGE_BACKEND=minio)
# Host-mode backend API usually uses localhost:9000
MINIO_ENDPOINT=localhost:9000
# Docker-internal endpoint used by celery-worker (optional override in compose)
# MINIO_INTERNAL_ENDPOINT=minio:9000
MINIO_BUCKET=documents
MINIO_ACCESS_KEY=minioadmin
# WARNING: Change in production
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false

# Public endpoint used when generating presigned URLs for browser access.
# Usually same as MINIO_ENDPOINT in local development.
MINIO_PUBLIC_ENDPOINT=localhost:9000

# MinIO Docker ports and server URL
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# MINIO_SERVER_URL=http://localhost:9000

# =============================================================================
# PostgreSQL Configuration (Required for RAG modes)
# =============================================================================

# PostgreSQL connection settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=newbee_notebook
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password

# =============================================================================
# Elasticsearch Configuration (Optional - for hybrid retrieval)
# =============================================================================

# Elasticsearch URL
ELASTICSEARCH_URL=http://localhost:9200

# =============================================================================
# Redis Configuration (Required for Celery async tasks)
# =============================================================================

# Redis connection settings (must match docker-compose.yml)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# =============================================================================
# Celery Configuration (Required for async document processing)
# =============================================================================

# Celery broker and result backend URLs
# IMPORTANT: When running API on host machine, use localhost:6379
#            When running API in Docker, use redis:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Celery worker concurrency (optional, default: number of CPU cores)
# For GPU PDF conversion, keep low concurrency to avoid memory spikes.
# CELERY_CONCURRENCY=1
# CELERY_PREFETCH_MULTIPLIER=1
# Restart worker child processes periodically to mitigate memory fragmentation.
# CELERY_MAX_TASKS_PER_CHILD=4
# Whether worker should call torch.cuda.empty_cache() after each document task.
# WORKER_CUDA_EMPTY_CACHE=true

# -----------------------------------------------------------------------------
# Document pipeline single-flight lock (recommended)
# -----------------------------------------------------------------------------
# Optional dedicated redis URL for pipeline lock. If not set, REDIS_URL /
# CELERY_BROKER_URL will be used automatically.
# PIPELINE_LOCK_REDIS_URL=redis://localhost:6379/0

# Lock TTL in seconds for one document pipeline execution.
# Increase this when processing very large documents.
# DOCUMENT_PIPELINE_LOCK_TTL_SECONDS=18000

# =============================================================================
# MinerU Configuration (Required for PDF processing)
# =============================================================================

# Enable/disable MinerU converters globally
# MINERU_ENABLED=true

# Processing mode:
# - cloud: MinerU official cloud service via v4 Smart Parsing API
# - local: local dockerized mineru-api service
MINERU_MODE=cloud

# ----------------------- Cloud mode settings -----------------------
# Required when MINERU_MODE=cloud
MINERU_API_KEY=

# Optional cloud settings
# MINERU_V4_API_BASE=https://mineru.net
# MINERU_V4_TIMEOUT=120
# MINERU_V4_POLL_INTERVAL=5
# MINERU_V4_MAX_WAIT_SECONDS=1800
# CDN 下载兜底：requests/OpenSSL 握手失败时，改用系统 curl
# MINERU_CDN_CURL_FALLBACK_ENABLED=true
# MINERU_CDN_CURL_BINARY=curl
# 紧急排障可用，默认不要开启
# MINERU_CDN_CURL_INSECURE=false
# MinerU circuit breaker (consecutive failures before cooldown)
# MINERU_FAIL_THRESHOLD=5
# MINERU_COOLDOWN_SECONDS=120

# ----------------------- Local mode settings -----------------------
# Default local API URL in Docker network
# MINERU_LOCAL_API_URL=http://mineru-api:8000

# Local backend:
# - pipeline (CPU)
# - hybrid-auto-engine (GPU)
# MINERU_BACKEND=pipeline

# OCR languages, comma-separated
# MINERU_LANG_LIST=ch,en

# Local processing timeout in seconds; 0 means no read timeout
# MINERU_LOCAL_TIMEOUT=0

# Max pages per MinerU batch request.
# MINERU_LOCAL_MAX_PAGES_PER_BATCH=50

# Retry transient local API failures (timeouts / connection errors / HTTP 5xx).
# Total attempts = 1 initial request + retry attempts.
# MINERU_LOCAL_REQUEST_RETRY_ATTEMPTS=2
# MINERU_LOCAL_RETRY_BACKOFF_SECONDS=10

# Return switches for local MinerU API response payload.
# Keep metadata enabled by default for viewer/debug/recovery workflows.
# MINERU_LOCAL_RETURN_IMAGES=true
# MINERU_LOCAL_RETURN_CONTENT_LIST=true
# MINERU_LOCAL_RETURN_MODEL_OUTPUT=true

# =============================================================================
# Flower (Optional monitoring, enabled via docker-compose profile \"monitor\")
# =============================================================================
# FLOWER_PORT=5555
