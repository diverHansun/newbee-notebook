# Project data/cache
# Ignore all runtime data by default.
data/*
# Keep base placeholders and docs.
!data/.gitkeep
!data/documents/
data/documents/*
!data/documents/README.md
!data/documents/.gitkeep
# Keep indexes/raw ignored explicitly for readability.
data/indexes/
data/raw/
/storage/
logs/
.cache/
*.db

# Generated indexes or models
indexes/
checkpoints/

# Project specific
*.log
.env.local
.env.*.local

# API keys and secrets (redundant but explicit)
*_API_KEY
*_SECRET
*_TOKEN

# Jupyter Notebook
.ipynb_checkpoints/

# IDE specific
*.swp
*.swo

# OS generated
Thumbs.db

